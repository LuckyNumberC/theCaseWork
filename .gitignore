# Dependencies — regenerated by npm install
node_modules/

# Credentials — never commit
.env
.env.local

# macOS metadata
.DS_Store

# WebdriverIO test artifacts — generated on each run
logs/
errorShots/
screenshots/
allure-results/

# npm/Node debug output
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor settings (optional — some teams commit these)
.vscode/
.idea/

